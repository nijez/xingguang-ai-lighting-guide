#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_TAIL_LOGS_VERSION="2026-06-29.1"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
INSTALL_DIR="${INSTALL_DIR:-$HOME/wainfort-light}"
LOG_DIR="${WAINFORT_LOG_DIR:-$BASE_DIR/wainfort-logs}"

redact() {
  sed -E \
    -e 's/(Bearer )[A-Za-z0-9._~+\/=-]+/\1***REDACTED***/g' \
    -e 's/(token["'"'"']?[=: ]+)[A-Za-z0-9._~+\/=-]+/\1***REDACTED***/Ig' \
    -e 's/(WAINFORT_[A-Z_]*TOKEN=).*/\1***REDACTED***/g' \
    -e 's/(api_key["'"'"']?[=: ]+)[A-Za-z0-9._~-]+/\1***REDACTED***/Ig'
}

main() {
  printf '最近灯光服务日志：\n'
  if [[ -f "$LOG_DIR/api.log" ]]; then
    tail -n "${1:-120}" "$LOG_DIR/api.log" | redact
  elif [[ -f "$INSTALL_DIR/api.log" ]]; then
    tail -n "${1:-120}" "$INSTALL_DIR/api.log" | redact
  else
    printf '暂未找到灯光服务日志。\n'
  fi

  if command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files 2>/dev/null | grep -q '^xinguang-wainfort.service'; then
    printf '\n最近系统服务日志：\n'
    journalctl -u xinguang-wainfort -n 80 --no-pager 2>/dev/null | redact || true
  fi
}

main "$@"
