#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_EXECUTE_LIGHT_VERSION="2026-07-01.1"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
INSTALL_DIR="${INSTALL_DIR:-$HOME/wainfort-light}"
ENV_PRIMARY="/etc/xinguang-wainfort.env"
ENV_FALLBACK="$INSTALL_DIR/.env"
PENDING_FILE="$BASE_DIR/pending-light-request.json"
PERMIT_FILE="$BASE_DIR/l6b-execute-permit.json"
REAL_PERMIT_FILE="$BASE_DIR/l6b-real-execute-permit.json"
RESTORE_PERMIT_FILE="$BASE_DIR/l6b-restore-permit.json"
REQUEST_LOG="$BASE_DIR/request-log.jsonl"
TARGET_NAME="门市 / 馨光RGBCW幻彩灯柱2"
API_PORT="${WAINFORT_API_PORT:-1888}"
API_TOKEN="${WAINFORT_API_TOKEN:-}"
EXECUTION_MODE="${XINGUANG_L6B_EXECUTION_MODE:-dry-run}"

direct_reply_begin() {
  printf '<!-- XINGUANG_DIRECT_REPLY_BEGIN copy-exactly -->\n'
}

direct_reply_end() {
  printf '<!-- XINGUANG_DIRECT_REPLY_END -->\n'
}

extract_request_id() {
  local text="$*"
  printf '%s\n' "$text" | grep -Eo 'xg-preview-[0-9]{14}-[0-9]{4}' | head -n 1 || true
}

load_env() {
  local env_file=""
  if [[ -r "$ENV_PRIMARY" ]]; then
    env_file="$ENV_PRIMARY"
  elif [[ -r "$ENV_FALLBACK" ]]; then
    env_file="$ENV_FALLBACK"
  fi
  if [[ -n "$env_file" ]]; then
    API_TOKEN="$(grep -E '^WAINFORT_API_TOKEN=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
    API_PORT="$(grep -E '^WAINFORT_API_PORT=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
  fi
  API_PORT="${API_PORT:-1888}"
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=False))' "$1"
}

validate_state() {
  local request_id="$1"
  python3 - "$PENDING_FILE" "$PERMIT_FILE" "$REAL_PERMIT_FILE" "$request_id" "$TARGET_NAME" "$EXECUTION_MODE" <<'PY'
import datetime, json, sys

pending_path, permit_path, real_permit_path, request_id, target_name, mode = sys.argv[1:7]
now = datetime.datetime.now().astimezone()

def fail(message):
    print(json.dumps({"ok": False, "message": message}, ensure_ascii=False))
    raise SystemExit(0)

try:
    with open(pending_path, "r", encoding="utf-8") as f:
        pending = json.load(f)
except Exception:
    fail("没有找到已确认的灯光预览，未执行。")

try:
    with open(permit_path, "r", encoding="utf-8") as f:
        permit = json.load(f)
except Exception:
    fail("执行许可未开启，未执行真实灯光控制。")

if pending.get("request_id") != request_id:
    fail("确认编号不匹配，未执行。")
if pending.get("target") != target_name:
    fail("目标设备不匹配，未执行。")
if pending.get("scope") != "single_device_only":
    fail("控制范围不安全，未执行。")
if pending.get("status") != "confirmed_ready":
    fail("当前确认状态不可执行，未执行。")
if pending.get("confirmed") is not True:
    fail("尚未完成执行确认，未执行。")
if pending.get("executed") is True:
    fail("该确认编号已经执行过，未重复执行。")
if permit.get("request_id") != request_id:
    fail("执行许可不匹配，未执行。")
if permit.get("target") != target_name:
    fail("执行许可目标不匹配，未执行。")
if permit.get("used") is True:
    fail("执行许可已使用，未重复执行。")
try:
    execute_expires = datetime.datetime.fromisoformat(str(pending.get("execute_expires_at", "")))
    permit_expires = datetime.datetime.fromisoformat(str(permit.get("expires_at", "")))
except Exception:
    fail("执行许可已失效，未执行。")
if execute_expires < now or permit_expires < now:
    fail("执行许可已过期，未执行。")

if mode == "real":
    try:
        with open(real_permit_path, "r", encoding="utf-8") as f:
            real_permit = json.load(f)
    except Exception:
        fail("真实执行许可未开启，未执行真实灯光控制。")
    if real_permit.get("request_id") != request_id:
        fail("真实执行许可不匹配，未执行真实灯光控制。")
    if real_permit.get("target") != target_name:
        fail("真实执行许可目标不匹配，未执行真实灯光控制。")
    if real_permit.get("scope") != "single_device_only":
        fail("真实执行许可范围不安全，未执行真实灯光控制。")
    if real_permit.get("action") != "execute_real":
        fail("真实执行许可类型不匹配，未执行真实灯光控制。")
    if real_permit.get("used") is True:
        fail("真实执行许可已使用，未重复执行。")
    try:
        real_expires = datetime.datetime.fromisoformat(str(real_permit.get("expires_at", "")))
    except Exception:
        fail("真实执行许可已失效，未执行真实灯光控制。")
    if real_expires < now:
        fail("真实执行许可已过期，未执行真实灯光控制。")

print(json.dumps({
    "ok": True,
    "request_id": request_id,
    "effect": pending.get("effect") or "低亮度暖色",
    "original_text": pending.get("original_text") or "",
    "dry_run": mode != "real",
}, ensure_ascii=False))
PY
}

mark_executed() {
  local request_id="$1" http_code="$2" response_file="$3"
  python3 - "$PENDING_FILE" "$PERMIT_FILE" "$REAL_PERMIT_FILE" "$RESTORE_PERMIT_FILE" "$REQUEST_LOG" "$request_id" "$http_code" "$response_file" "$EXECUTION_MODE" <<'PY'
import datetime, json, os, sys

pending_path, permit_path, real_permit_path, restore_permit_path, log_path, request_id, http_code, response_file, mode = sys.argv[1:10]
now = datetime.datetime.now().astimezone()
try:
    with open(pending_path, "r", encoding="utf-8") as f:
        pending = json.load(f)
except Exception:
    pending = {}
try:
    with open(permit_path, "r", encoding="utf-8") as f:
        permit = json.load(f)
except Exception:
    permit = {}
try:
    with open(real_permit_path, "r", encoding="utf-8") as f:
        real_permit = json.load(f)
except Exception:
    real_permit = {}

if pending.get("request_id") == request_id:
    pending["executed"] = True
    pending["executed_at"] = now.isoformat()
    pending["status"] = "executed_once"
    with open(pending_path, "w", encoding="utf-8") as f:
        json.dump(pending, f, ensure_ascii=False, indent=2)
        f.write("\n")

if permit.get("request_id") == request_id:
    permit["used"] = True
    permit["used_at"] = now.isoformat()
    with open(permit_path, "w", encoding="utf-8") as f:
        json.dump(permit, f, ensure_ascii=False, indent=2)
        f.write("\n")

if real_permit.get("request_id") == request_id:
    real_permit["used"] = True
    real_permit["used_at"] = now.isoformat()
    with open(real_permit_path, "w", encoding="utf-8") as f:
        json.dump(real_permit, f, ensure_ascii=False, indent=2)
        f.write("\n")

restore_permit = {
    "request_id": request_id,
    "target": "门市 / 馨光RGBCW幻彩灯柱2",
    "action": "restore",
    "created_at": now.isoformat(),
    "expires_at": (now + datetime.timedelta(minutes=5)).isoformat(),
    "used": False,
}
with open(restore_permit_path, "w", encoding="utf-8") as f:
    json.dump(restore_permit, f, ensure_ascii=False, indent=2)
    f.write("\n")
try:
    os.chmod(restore_permit_path, 0o600)
except Exception:
    pass

try:
    body = open(response_file, encoding="utf-8", errors="replace").read()[:500]
except Exception:
    body = ""
entry = {
    "ts": now.isoformat(),
    "request_id": request_id,
    "stage": "l6b_execute",
    "target": "门市 / 馨光RGBCW幻彩灯柱2",
    "scope": "single_device_only",
    "mode": mode,
    "service_called": mode == "real" and http_code not in ("", "000"),
    "http_code": http_code,
    "response_summary": body,
}
os.makedirs(os.path.dirname(log_path), exist_ok=True)
with open(log_path, "a", encoding="utf-8") as f:
    f.write(json.dumps(entry, ensure_ascii=False) + "\n")
PY
}

main() {
  local request_id validation ok msg response_file http_code payload
  request_id="$(extract_request_id "$@")"

  direct_reply_begin
  if [[ -z "$request_id" ]]; then
    printf '执行确认编号不完整，未执行。\n'
    direct_reply_end
    return 0
  fi

  mkdir -p "$BASE_DIR"
  validation="$(validate_state "$request_id")"
  ok="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("ok"))' <<<"$validation" 2>/dev/null || printf 'False')"
  if [[ "$ok" != "True" ]]; then
    msg="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("message","未执行。"))' <<<"$validation" 2>/dev/null || printf '未执行。')"
    printf '%s\n' "$msg"
    direct_reply_end
    return 0
  fi

  if [[ "$EXECUTION_MODE" != "real" ]]; then
    printf '已通过执行前检查。\n'
    printf 'would_execute=true\n'
    printf '当前为 dry-run 验证模式，未执行真实灯光控制。\n'
    direct_reply_end
    return 0
  fi

  load_env
  if [[ -z "$API_TOKEN" ]]; then
    printf '灯光服务暂时无法执行，请联系工作人员处理。\n'
    direct_reply_end
    return 0
  fi

  if ! ss -ltn 2>/dev/null | grep -qE "[:.]$API_PORT\\b"; then
    printf '灯光服务暂时无法执行，请联系工作人员处理。\n'
    direct_reply_end
    return 0
  fi

  local status_code devices_code devices_file
  status_code="$(curl -sS --max-time 8 -o /dev/null -w '%{http_code}' \
    -H "Authorization: Bearer $API_TOKEN" \
    "http://127.0.0.1:$API_PORT/api/status" 2>/dev/null || true)"
  if [[ "$status_code" != "200" ]]; then
    printf '灯光服务暂时无法执行，请联系工作人员处理。\n'
    direct_reply_end
    return 0
  fi

  devices_file="$(mktemp "${TMPDIR:-/tmp}/xinguang-devices.XXXXXX")"
  devices_code="$(curl -sS --max-time 8 -o "$devices_file" -w '%{http_code}' \
    -H "Authorization: Bearer $API_TOKEN" \
    "http://127.0.0.1:$API_PORT/api/devices" 2>/dev/null || true)"
  if [[ "$devices_code" != "200" ]] || ! grep -q '馨光RGBCW幻彩灯柱2' "$devices_file"; then
    rm -f "$devices_file"
    printf '目标灯光设备暂时无法确认，请联系工作人员处理。\n'
    direct_reply_end
    return 0
  fi
  rm -f "$devices_file"

  response_file="$(mktemp "${TMPDIR:-/tmp}/xinguang-execute.XXXXXX")"
  trap 'rm -f "${response_file:-}"' EXIT
  payload="$(printf '{"request_id":%s,"room":%s,"scene":%s,"text":%s,"single_shot":true}' \
    "$(json_escape "$request_id")" \
    "$(json_escape "门市")" \
    "$(json_escape "低亮度暖色")" \
    "$(json_escape "门市灯柱低亮度暖色")")"
  http_code="$(curl -sS --max-time 30 -o "$response_file" -w '%{http_code}' \
    -H "Authorization: Bearer $API_TOKEN" \
    -H 'Content-Type: application/json' \
    -d "$payload" \
    "http://127.0.0.1:$API_PORT/api/generate" 2>/dev/null || true)"

  if [[ "$http_code" == "200" ]]; then
    mark_executed "$request_id" "$http_code" "$response_file"
    printf '已发送门市灯柱低亮度暖色测试。\n'
    printf '请现场观察 5-10 秒，只确认门市灯柱是否变化。\n'
  else
    printf '灯光请求未完成，请联系工作人员处理。\n'
  fi
  direct_reply_end
}

main "$@"
