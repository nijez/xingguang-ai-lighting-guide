#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_RESTORE_LIGHT_VERSION="2026-07-01.1"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
INSTALL_DIR="${INSTALL_DIR:-$HOME/wainfort-light}"
ENV_PRIMARY="/etc/xinguang-wainfort.env"
ENV_FALLBACK="$INSTALL_DIR/.env"
PENDING_FILE="$BASE_DIR/pending-light-request.json"
RESTORE_PERMIT_FILE="$BASE_DIR/l6b-restore-permit.json"
REQUEST_LOG="$BASE_DIR/request-log.jsonl"
TARGET_NAME="门市 / 馨光RGBCW幻彩灯柱2"
API_PORT="${WAINFORT_API_PORT:-1888}"
API_TOKEN="${WAINFORT_API_TOKEN:-}"
EXECUTION_MODE="${XINGUANG_L6B_EXECUTION_MODE:-auto}"

direct_reply_begin() {
  printf '<!-- XINGUANG_DIRECT_REPLY_BEGIN copy-exactly -->\n'
}

direct_reply_end() {
  printf '<!-- XINGUANG_DIRECT_REPLY_END -->\n'
}

extract_request_id() {
  local text="$*"
  printf '%s\n' "$text" | grep -Eo 'xg-preview-[0-9]{14}-[0-9]{4}' | head -n 1 || true
}

load_env() {
  local env_file=""
  if [[ -r "$ENV_PRIMARY" ]]; then
    env_file="$ENV_PRIMARY"
  elif [[ -r "$ENV_FALLBACK" ]]; then
    env_file="$ENV_FALLBACK"
  fi
  if [[ -n "$env_file" ]]; then
    API_TOKEN="$(grep -E '^WAINFORT_API_TOKEN=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
    API_PORT="$(grep -E '^WAINFORT_API_PORT=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
  fi
  API_PORT="${API_PORT:-1888}"
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=False))' "$1"
}

validate_state() {
  local request_id="$1"
  python3 - "$PENDING_FILE" "$RESTORE_PERMIT_FILE" "$request_id" "$TARGET_NAME" "$EXECUTION_MODE" <<'PY'
import datetime, json, sys

pending_path, restore_permit_path, request_id, target_name, mode = sys.argv[1:6]
now = datetime.datetime.now().astimezone()

def fail(message):
    print(json.dumps({"ok": False, "message": message}, ensure_ascii=False))
    raise SystemExit(0)

try:
    with open(pending_path, "r", encoding="utf-8") as f:
        pending = json.load(f)
except Exception:
    fail("没有找到可恢复的灯光请求，未执行恢复。")

try:
    with open(restore_permit_path, "r", encoding="utf-8") as f:
        restore_permit = json.load(f)
except Exception:
    fail("恢复许可未开启，未执行恢复。")

if pending.get("request_id") != request_id:
    fail("确认编号不匹配，未执行恢复。")
if pending.get("target") != target_name:
    fail("目标设备不匹配，未执行恢复。")
if pending.get("status") != "executed_once":
    fail("当前状态不可恢复，未执行恢复。")
if pending.get("executed") is not True:
    fail("尚未执行灯光测试，未执行恢复。")
if pending.get("restored") is True:
    fail("该确认编号已经恢复过，未重复恢复。")
if restore_permit.get("request_id") != request_id:
    fail("恢复许可不匹配，未执行恢复。")
if restore_permit.get("target") != target_name:
    fail("恢复许可目标不匹配，未执行恢复。")
if restore_permit.get("action") != "restore":
    fail("恢复许可类型不匹配，未执行恢复。")
if restore_permit.get("used") is True:
    fail("恢复许可已使用，未重复恢复。")
try:
    restore_expires = datetime.datetime.fromisoformat(str(restore_permit.get("expires_at", "")))
except Exception:
    fail("恢复许可已失效，未执行恢复。")
if restore_expires < now:
    fail("恢复许可已过期，未执行恢复。")

print(json.dumps({"ok": True, "request_id": request_id, "dry_run": mode == "dry-run"}, ensure_ascii=False))
PY
}

mark_restored() {
  local request_id="$1" http_code="$2" response_file="$3"
  python3 - "$PENDING_FILE" "$RESTORE_PERMIT_FILE" "$REQUEST_LOG" "$request_id" "$http_code" "$response_file" "$EXECUTION_MODE" <<'PY'
import datetime, json, os, sys

pending_path, restore_permit_path, log_path, request_id, http_code, response_file, mode = sys.argv[1:8]
now = datetime.datetime.now().astimezone()
try:
    with open(pending_path, "r", encoding="utf-8") as f:
        pending = json.load(f)
except Exception:
    pending = {}
try:
    with open(restore_permit_path, "r", encoding="utf-8") as f:
        restore_permit = json.load(f)
except Exception:
    restore_permit = {}
if pending.get("request_id") == request_id:
    pending["restored"] = True
    pending["restored_at"] = now.isoformat()
    pending["status"] = "restored_once"
    with open(pending_path, "w", encoding="utf-8") as f:
        json.dump(pending, f, ensure_ascii=False, indent=2)
        f.write("\n")
if restore_permit.get("request_id") == request_id:
    restore_permit["used"] = True
    restore_permit["used_at"] = now.isoformat()
    with open(restore_permit_path, "w", encoding="utf-8") as f:
        json.dump(restore_permit, f, ensure_ascii=False, indent=2)
        f.write("\n")
try:
    body = open(response_file, encoding="utf-8", errors="replace").read()[:500]
except Exception:
    body = ""
entry = {
    "ts": now.isoformat(),
    "request_id": request_id,
    "stage": "l6b_restore",
    "target": "门市 / 馨光RGBCW幻彩灯柱2",
    "scope": "single_device_only",
    "mode": mode,
    "service_called": http_code not in ("", "000"),
    "http_code": http_code,
    "response_summary": body,
}
os.makedirs(os.path.dirname(log_path), exist_ok=True)
with open(log_path, "a", encoding="utf-8") as f:
    f.write(json.dumps(entry, ensure_ascii=False) + "\n")
PY
}

main() {
  local request_id validation ok msg response_file http_code payload
  request_id="$(extract_request_id "$@")"

  direct_reply_begin
  if [[ -z "$request_id" ]]; then
    printf '恢复确认编号不完整，未执行恢复。\n'
    direct_reply_end
    return 0
  fi

  validation="$(validate_state "$request_id")"
  ok="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("ok"))' <<<"$validation" 2>/dev/null || printf 'False')"
  if [[ "$ok" != "True" ]]; then
    msg="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("message","未执行恢复。"))' <<<"$validation" 2>/dev/null || printf '未执行恢复。')"
    printf '%s\n' "$msg"
    direct_reply_end
    return 0
  fi

  if [[ "$EXECUTION_MODE" != "real" ]]; then
    local is_dry_run
    is_dry_run="$(python3 -c 'import json,sys; print(json.loads(sys.stdin.read()).get("dry_run", True))' <<<"$validation" 2>/dev/null || printf 'True')"
    if [[ "$is_dry_run" == "True" ]]; then
      printf '已通过恢复前检查。\n'
      printf 'would_restore=true\n'
      printf '当前为 dry-run 验证模式，未执行真实恢复。\n'
      direct_reply_end
      return 0
    fi
  fi

  load_env
  if [[ -z "$API_TOKEN" ]]; then
    printf '灯光服务暂时无法恢复，请联系工作人员处理。\n'
    direct_reply_end
    return 0
  fi

  response_file="$(mktemp "${TMPDIR:-/tmp}/xinguang-restore.XXXXXX")"
  trap 'rm -f "${response_file:-}"' EXIT
  payload="$(printf '{"request_id":%s,"room":%s,"scene":%s,"text":%s,"single_shot":true}' \
    "$(json_escape "$request_id")" \
    "$(json_escape "门市")" \
    "$(json_escape "柔和白光")" \
    "$(json_escape "门市灯柱恢复柔和白光")")"
  http_code="$(curl -sS --max-time 30 -o "$response_file" -w '%{http_code}' \
    -H "Authorization: Bearer $API_TOKEN" \
    -H 'Content-Type: application/json' \
    -d "$payload" \
    "http://127.0.0.1:$API_PORT/api/generate" 2>/dev/null || true)"

  if [[ "$http_code" == "200" ]]; then
    mark_restored "$request_id" "$http_code" "$response_file"
    printf '已发送门市灯柱恢复白光请求。\n'
    printf '请现场确认是否恢复，且其他设备没有变化。\n'
  else
    printf '灯光恢复未完成，请联系工作人员处理。\n'
  fi
  direct_reply_end
}

main "$@"
