#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_ARM_L6B_REAL_VERSION="2026-07-01.2"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
PENDING_FILE="$BASE_DIR/pending-light-request.json"
PERMIT_FILE="$BASE_DIR/l6b-execute-permit.json"
REAL_PERMIT_FILE="$BASE_DIR/l6b-real-execute-permit.json"
TARGET_NAME="门市 / 馨光RGBCW幻彩灯柱2"

direct_reply_begin() {
  printf '<!-- XINGUANG_DIRECT_REPLY_BEGIN copy-exactly -->\n'
}

direct_reply_end() {
  printf '<!-- XINGUANG_DIRECT_REPLY_END -->\n'
}

extract_request_id() {
  local text="$*"
  printf '%s\n' "$text" | grep -Eo 'xg-preview-[0-9]{14}-[0-9]{4}' | head -n 1 || true
}

reply_and_exit() {
  direct_reply_begin
  printf '%s\n' "$1"
  direct_reply_end
  exit 0
}

require_interactive_terminal() {
  if ! { exec 9<>/dev/tty; } 2>/dev/null; then
    reply_and_exit "真实执行许可只能由工作人员在交互式终端开启，当前未开启。"
  fi
}

require_manual_confirmation() {
  local request_id="$1"
  local expected="允许真实执行 ${request_id}"
  local confirmation=""

  {
    printf '即将为以下确认编号开启一次性真实执行许可：%s\n' "$request_id"
    printf '请输入确认短语：%s\n' "$expected"
    printf '> '
  } >&9

  if ! IFS= read -r confirmation <&9; then
    reply_and_exit "未收到人工确认，未开启真实执行许可。"
  fi

  if [[ "$confirmation" != "$expected" ]]; then
    reply_and_exit "人工确认短语不匹配，未开启真实执行许可。"
  fi
}

main() {
  local request_id
  request_id="$(extract_request_id "$@")"

  if [[ -z "$request_id" ]]; then
    reply_and_exit "真实执行确认编号不完整，未开启真实执行许可。"
  fi

  require_interactive_terminal
  require_manual_confirmation "$request_id"

  direct_reply_begin
  mkdir -p "$BASE_DIR"
  python3 - "$PENDING_FILE" "$PERMIT_FILE" "$REAL_PERMIT_FILE" "$request_id" "$TARGET_NAME" <<'PY'
import datetime, json, os, sys

pending_path, permit_path, real_permit_path, request_id, target_name = sys.argv[1:6]
now = datetime.datetime.now().astimezone()

def fail(message):
    print(message)
    raise SystemExit(0)

try:
    with open(pending_path, "r", encoding="utf-8") as f:
        pending = json.load(f)
except Exception:
    fail("没有找到已确认的灯光预览，未开启真实执行许可。")

try:
    with open(permit_path, "r", encoding="utf-8") as f:
        permit = json.load(f)
except Exception:
    fail("执行许可未开启，未开启真实执行许可。")

if pending.get("request_id") != request_id:
    fail("确认编号不匹配，未开启真实执行许可。")
if pending.get("target") != target_name:
    fail("目标设备不匹配，未开启真实执行许可。")
if pending.get("scope") != "single_device_only":
    fail("控制范围不安全，未开启真实执行许可。")
if pending.get("status") != "confirmed_ready":
    fail("当前确认状态不可真实执行，未开启真实执行许可。")
if pending.get("confirmed") is not True:
    fail("尚未完成执行确认，未开启真实执行许可。")
if pending.get("executed") is True:
    fail("该确认编号已经执行过，未开启真实执行许可。")
if permit.get("request_id") != request_id:
    fail("执行许可不匹配，未开启真实执行许可。")
if permit.get("target") != target_name:
    fail("执行许可目标不匹配，未开启真实执行许可。")
if permit.get("used") is True:
    fail("执行许可已使用，未开启真实执行许可。")

try:
    execute_expires = datetime.datetime.fromisoformat(str(pending.get("execute_expires_at", "")))
    permit_expires = datetime.datetime.fromisoformat(str(permit.get("expires_at", "")))
except Exception:
    fail("执行许可已失效，未开启真实执行许可。")
if execute_expires < now or permit_expires < now:
    fail("执行许可已过期，未开启真实执行许可。")

real_expires = now + datetime.timedelta(seconds=120)
real_permit = {
    "request_id": request_id,
    "target": target_name,
    "scope": "single_device_only",
    "action": "execute_real",
    "created_at": now.isoformat(),
    "expires_at": real_expires.isoformat(),
    "used": False,
}
with open(real_permit_path, "w", encoding="utf-8") as f:
    json.dump(real_permit, f, ensure_ascii=False, indent=2)
    f.write("\n")
try:
    os.chmod(real_permit_path, 0o600)
except Exception:
    pass

print("已开启一次性真实执行许可。")
print(f"确认编号：{request_id}")
print("目标：门市 / 馨光RGBCW幻彩灯柱2")
print("范围：只控制这一台")
print("有效期：120 秒")
print("下一步请发送：")
print(f"执行 {request_id}，把门市灯柱调成低亮度暖色，只调这一台")
PY
  direct_reply_end
}

main "$@"
