ensure_miloco_plugin_package() {
  [[ "$(uname -m)" == "x86_64" ]] || die "当前兼容安装仅支持腾讯云 x86_64 龙虾服务器"

  download_sha256 "$MILOCO_BUNDLE" "$MILOCO_BUNDLE_SHA256" \
    "https://github.com/XiaoMi/xiaomi-miloco/releases/download/v$MILOCO_VERSION/miloco-linux-x86_64-$MILOCO_VERSION.tar.gz" \
    "https://ghfast.top/https://github.com/XiaoMi/xiaomi-miloco/releases/download/v$MILOCO_VERSION/miloco-linux-x86_64-$MILOCO_VERSION.tar.gz" \
    "https://ghproxy.net/https://github.com/XiaoMi/xiaomi-miloco/releases/download/v$MILOCO_VERSION/miloco-linux-x86_64-$MILOCO_VERSION.tar.gz" ||
    die "Miloco 官方插件包下载或校验失败"

  if [[ -f "$MILOCO_PLUGIN_TGZ" ]] &&
    [[ "$(sha256_of "$MILOCO_PLUGIN_TGZ" 2>/dev/null || true)" == "$MILOCO_PLUGIN_TGZ_SHA256" ]]; then
    return 0
  fi

  local tmp plugin_member
  tmp="$(mktemp "$CACHE_DIR/plugin.XXXXXX.tgz")"
  plugin_member="$(tar -tzf "$MILOCO_BUNDLE" 2>/dev/null |
    awk -v name="miloco-openclaw-plugin-$MILOCO_VERSION.tgz" \
      '($0 == name || $0 == "./" name) && !found { print; found=1 }')"
  if [[ -z "$plugin_member" ]] ||
    ! tar -xOf "$MILOCO_BUNDLE" "$plugin_member" >"$tmp" 2>/dev/null; then
    rm -f "$tmp"
    die "Miloco 官方插件包解压失败"
  fi
  if [[ "$(sha256_of "$tmp" 2>/dev/null || true)" != "$MILOCO_PLUGIN_TGZ_SHA256" ]]; then
    rm -f "$tmp"
    die "Miloco 官方插件包校验失败"
  fi
  mv "$tmp" "$MILOCO_PLUGIN_TGZ"
}

