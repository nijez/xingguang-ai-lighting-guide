miloco_running() {
  have miloco-cli || return 1
  local output
  output="$(timeout 20s miloco-cli service status 2>/dev/null || true)"
  grep -Eiq '"running"[[:space:]]*:[[:space:]]*true|running[[:space:]]*[:=][[:space:]]*true|运行中' <<<"$output"
}

version_compare() {
  local a="$1" b="$2" top
  if [[ "$a" == "$b" ]]; then
    printf '%s' '0'
    return 0
  fi
  top="$(printf '%s\n%s\n' "$a" "$b" | sort -V | tail -n1 || true)"
  if [[ "$top" == "$a" ]]; then
    printf '%s' '1'
  else
    printf '%s' '-1'
  fi
}

installed_miloco_version() {
  have miloco-cli || return 1
  local output version
  output="$(timeout 20s miloco-cli version 2>/dev/null || true)"
  [[ -n "$output" ]] || output="$(timeout 20s miloco-cli --version 2>/dev/null || true)"
  version="$(printf '%s' "$output" |
    grep -oE '"version"[[:space:]]*:[[:space:]]*"[0-9]+\.[0-9]+(\.[0-9]+)?"' |
    head -1 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' || true)"
  if [[ -z "$version" ]]; then
    version="$(printf '%s' "$output" | grep -oE '[0-9]{4}\.[0-9]{1,2}(\.[0-9]{1,2})?' | head -1 || true)"
  fi
  [[ -n "$version" ]] || return 1
  printf '%s' "$version"
}

miloco_plugin_present() {
  have openclaw || return 1
  timeout 20s openclaw plugins list 2>/dev/null | grep -qi 'miloco'
}

miloco_up_to_date() {
  local version
  version="$(installed_miloco_version 2>/dev/null || true)"
  [[ -n "$version" ]] || return 1
  [[ "$version" == "$MILOCO_RECOMMENDED_VERSION" ]] || return 1
  miloco_running || return 1
  miloco_plugin_present || return 1
  return 0
}

miloco_scheduler_state() {
  if ! have miloco-cli; then
    printf '无法确认'
    return 0
  fi
  local version
  version="$(installed_miloco_version 2>/dev/null || true)"
  if [[ -z "$version" ]]; then
    printf '无法确认'
    return 0
  fi
  if [[ "$(version_compare "$version" "$MILOCO_SCHEDULER_MIN_VERSION")" == "-1" ]]; then
    printf '当前版本不支持'
    return 0
  fi
  local output collapsed
  output="$(timeout 20s miloco-cli config get scheduler.enabled 2>/dev/null || true)"
  # 官方 CLI（cli/src/miloco_cli/commands/config.py）默认输出
  # print_result({"path": path, "value": value}, pretty)，可能是压缩或
  # 缩进多行 JSON，去除全部空白后统一按紧凑 JSON 匹配，同时兼容旧格式。
  collapsed="$(tr -d '[:space:]' <<<"$output")"
  if grep -Eiq '"value":true|"enabled":true|scheduler\.enabled[:=]true|^true$' <<<"$collapsed"; then
    printf '开启'
  elif grep -Eiq '"value":false|"enabled":false|scheduler\.enabled[:=]false|^false$' <<<"$collapsed"; then
    printf '关闭'
  else
    printf '无法确认'
  fi
}

mimo_key_configured() {
  have miloco-cli || return 1
  local output
  output="$(timeout 20s miloco-cli config get model.omni.api_key 2>/dev/null || true)"
  [[ -n "$output" ]] || return 1
  ! grep -Eq '^[[:space:]]*$|""|null|None|未配置|not set' <<<"$output"
}

account_bound() {
  have miloco-cli || return 1
  local args output
  for args in "account status" "account info"; do
    output="$(timeout 20s miloco-cli $args 2>/dev/null || true)"
    if grep -Eiq '"is_bound"[[:space:]]*:[[:space:]]*true|is_bound[[:space:]]*[:=][[:space:]]*true|bound[[:space:]]*[:=][[:space:]]*true|已绑定' <<<"$output"; then
      return 0
    fi
  done
  return 1
}

installed_skill_version() {
  local skill_file="$HOME/.openclaw/skills/$SKILL_NAME/SKILL.md"
  [[ -f "$skill_file" ]] || return 1
  grep -o '"version":"[^"]*"' "$skill_file" 2>/dev/null |
    head -1 | sed -E 's/"version":"([^"]*)"/\1/'
}

read_wainfort_token() {
  local value=""
  if sudo test -f /etc/xinguang-wainfort.env 2>/dev/null; then
    value="$(sudo awk -F= '$1 == "WAINFORT_API_TOKEN" {sub(/^[^=]*=/, ""); value=$0} END {print value}' /etc/xinguang-wainfort.env 2>/dev/null || true)"
  fi
  if [[ -z "$value" && -f "$HOME/wainfort-light/.env" ]]; then
    value="$(awk -F= '$1 == "WAINFORT_API_TOKEN" {sub(/^[^=]*=/, ""); value=$0} END {print value}' "$HOME/wainfort-light/.env" 2>/dev/null || true)"
  fi
  printf '%s' "$value"
}

lighting_service_ready() {
  local token code
  token="$(read_wainfort_token)"
  [[ -n "$token" ]] || return 1
  code="$(curl -sS --max-time 10 -o /dev/null -w '%{http_code}' \
    -H "Authorization: Bearer $token" \
    http://127.0.0.1:1888/api/devices 2>/dev/null || true)"
  unset token
  [[ "$code" == 200 ]]
}

skill_registered() {
  have openclaw || return 1
  timeout 30s openclaw skills info "$SKILL_NAME" >/dev/null 2>&1 && return 0
  timeout 30s openclaw skills list 2>/dev/null | grep -Fqi "$SKILL_NAME"
}

gateway_ready() {
  have openclaw || return 1
  timeout 30s openclaw gateway status --deep >/dev/null 2>&1
}

saved_home_values() {
  [[ -f "$TARGET_HOME_FILE" ]] || return 1
  bash -c 'source "$1" 2>/dev/null; printf "%s\t%s\n" "${XINGUANG_TARGET_HOME_ID:-}" "${XINGUANG_TARGET_HOME:-}"' _ "$TARGET_HOME_FILE"
}

current_active_home() {
  query_homes || return 1
  awk -F '\t' '$3 == 1 {count++; row=$0} END {if (count == 1) print row; else exit 1}' "$HOME_LIST_TSV"
}

print_status() {
  setup_paths
  local openclaw_state="未安装"
  local miloco_state="未安装"
  local key_state="未配置"
  local account_state="未绑定"
  local home_state="未选择"
  local skill_state="未安装"
  local value saved_home saved_home_id saved_home_name active_home active_home_id active_home_name
  local gateway_ok=0
  local home_ok=0
  local miloco_version scheduler_state

  if have openclaw; then
    if gateway_ready; then
      openclaw_state="$(openclaw --version 2>/dev/null | head -1 || printf '已安装')，后台服务正常"
      gateway_ok=1
    else
      openclaw_state="$(openclaw --version 2>/dev/null | head -1 || printf '已安装')，后台服务未就绪"
    fi
  fi
  if have miloco-cli; then
    miloco_version="$(installed_miloco_version 2>/dev/null || true)"
    if [[ -z "$miloco_version" ]]; then
      miloco_state="已安装（版本无法确认）"
    elif [[ "$miloco_version" == "$MILOCO_RECOMMENDED_VERSION" ]]; then
      miloco_state="已安装 ${miloco_version}（推荐版本）"
    elif [[ "$(version_compare "$miloco_version" "$MILOCO_RECOMMENDED_VERSION")" == "-1" ]]; then
      miloco_state="已安装 ${miloco_version}（低于推荐版本 ${MILOCO_RECOMMENDED_VERSION}，可通过安装/修复自动升级）"
    else
      miloco_state="已安装 ${miloco_version}（高于推荐版本 ${MILOCO_RECOMMENDED_VERSION}，不自动降级）"
    fi
    if miloco_running; then
      miloco_state="${miloco_state}，运行中"
    else
      miloco_state="${miloco_state}，未运行"
    fi
  fi
  scheduler_state="$(miloco_scheduler_state 2>/dev/null || true)"
  mimo_key_configured && key_state="已配置"
  account_bound && account_state="已绑定"
  saved_home="$(saved_home_values 2>/dev/null || true)"
  IFS=$'\t' read -r saved_home_id saved_home_name <<<"$saved_home"
  if [[ -n "$saved_home_id" && -n "$saved_home_name" && "$account_state" == "已绑定" ]]; then
    active_home="$(current_active_home 2>/dev/null || true)"
    IFS=$'\t' read -r active_home_id active_home_name _ <<<"$active_home"
    if [[ "$active_home_id" == "$saved_home_id" && "$active_home_name" == "$saved_home_name" ]]; then
      home_state="${saved_home_name}（已启用）"
      home_ok=1
    elif [[ -n "$active_home_name" ]]; then
      home_state="${saved_home_name}（当前启用的是 ${active_home_name}）"
    else
      home_state="${saved_home_name}（当前状态无法确认）"
    fi
  elif [[ -n "$saved_home_name" ]]; then
    home_state="${saved_home_name}（账号状态未确认）"
  fi
  value="$(installed_skill_version 2>/dev/null || true)"
  if [[ -n "$value" ]]; then
    if [[ "$value" == "$SKILL_VERSION" ]] && [[ "$key_state" == "已配置" ]] &&
      ((gateway_ok == 1)) && ((home_ok == 1)) &&
      skill_registered && lighting_service_ready; then
      skill_state="已安装并就绪，版本 $value"
    else
      skill_state="文件已安装，但运行条件未就绪，版本 $value"
    fi
  fi

  cat <<EOF

当前状态
----------------------------------------
龙虾环境：        $openclaw_state
Miloco 2.0：      $miloco_state
Miloco 自动定时任务： $scheduler_state
Miloco MiMo Key： $key_state
米家账号：        $account_state
目标家庭：        $home_state
馨光 Skill：      $skill_state
----------------------------------------
EOF
}

