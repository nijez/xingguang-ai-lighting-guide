setup_paths() {
  export PATH="$LOCAL_BIN_DIR:$HOME/.local/share/uv/tools/miloco-cli/bin:$PATH"

  local node_bin
  node_bin="$(find "$HOME/.nvm/versions/node" -mindepth 2 -maxdepth 2 -type d -name bin 2>/dev/null | sort -V | tail -1 || true)"
  if [[ -n "$node_bin" ]]; then
    export PATH="$node_bin:$PATH"
  fi
}

have() {
  command -v "$1" >/dev/null 2>&1
}

die() {
  printf '\n错误：%s\n' "$1" >&2
  exit 1
}

pause_menu() {
  printf '\n按 Enter 返回菜单...'
  IFS= read -r _ || true
}

confirm() {
  local prompt="$1"
  local answer
  printf '%s [y/N]: ' "$prompt"
  IFS= read -r answer || answer=""
  case "$answer" in
    y|Y|yes|YES|Yes) return 0 ;;
    *) return 1 ;;
  esac
}

install_self() {
  mkdir -p "$LOCAL_BIN_DIR" "$CACHE_DIR"
  if [[ "$SCRIPT_PATH" != "$SELF_TARGET" ]]; then
    install -m 0755 "$SCRIPT_PATH" "$SELF_TARGET"
  fi
}

benchmark_download_url() {
  local url="$1"
  curl -fsSL --range 0-262143 --connect-timeout 5 --max-time 8 \
    -o /dev/null -w '%{time_total}' "$url" 2>/dev/null
}

rank_download_urls() {
  local -a urls=("$@")
  local result_file failed_file url elapsed
  result_file="$(mktemp "$CACHE_DIR/source-speed.XXXXXX")"
  failed_file="$(mktemp "$CACHE_DIR/source-failed.XXXXXX")"

  for url in "${urls[@]}"; do
    if elapsed="$(benchmark_download_url "$url")"; then
      printf '%s\t%s\n' "$elapsed" "$url" >>"$result_file"
    else
      printf '%s\n' "$url" >>"$failed_file"
    fi
  done

  if [[ -s "$result_file" ]]; then
    sort -n "$result_file" | cut -f2-
  fi
  cat "$failed_file"
  rm -f "$result_file" "$failed_file"
}

download_versioned() {
  local target="$1"
  local marker="$2"
  local expected_sha="$3"
  shift 3

  if [[ -f "$target" ]] && grep -Fq "$marker" "$target" &&
    [[ "$(sha256_of "$target" 2>/dev/null || true)" == "$expected_sha" ]]; then
    chmod +x "$target"
    return 0
  fi

  local tmp url
  local -a ranked_urls
  tmp="$(mktemp "$CACHE_DIR/download.XXXXXX")"
  mapfile -t ranked_urls < <(rank_download_urls "$@")
  for url in "${ranked_urls[@]}"; do
    if curl -fL --retry 1 --retry-delay 1 --connect-timeout 8 \
      --speed-limit 1024 --speed-time 20 --max-time 120 \
      -o "$tmp" "$url" && grep -Fq "$marker" "$tmp" &&
      [[ "$(sha256_of "$tmp" 2>/dev/null || true)" == "$expected_sha" ]]; then
      mv "$tmp" "$target"
      chmod +x "$target"
      return 0
    fi
  done

  rm -f "$tmp"
  return 1
}

download_sha256() {
  local target="$1"
  local expected_sha="$2"
  shift 2

  if [[ -f "$target" ]] &&
    [[ "$(sha256_of "$target" 2>/dev/null || true)" == "$expected_sha" ]]; then
    return 0
  fi

  local tmp url
  local -a ranked_urls
  tmp="$(mktemp "$CACHE_DIR/download.XXXXXX")"
  mapfile -t ranked_urls < <(rank_download_urls "$@")
  for url in "${ranked_urls[@]}"; do
    if curl -fL --retry 1 --retry-delay 1 --connect-timeout 8 \
      --speed-limit 1024 --speed-time 20 --max-time 600 \
      -o "$tmp" "$url" &&
      [[ "$(sha256_of "$tmp" 2>/dev/null || true)" == "$expected_sha" ]]; then
      mv "$tmp" "$target"
      return 0
    fi
  done

  rm -f "$tmp"
  return 1
}

sha256_of() {
  if have sha256sum; then
    sha256sum "$1" | awk '{print $1}'
  elif have shasum; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    return 1
  fi
}

