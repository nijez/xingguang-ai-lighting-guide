miloco_install_decision() {
  local installed
  installed="$(installed_miloco_version 2>/dev/null || true)"
  if [[ -z "$installed" ]]; then
    printf 'install'
    return 0
  fi
  if [[ "$(version_compare "$installed" "$MILOCO_RECOMMENDED_VERSION")" == "1" ]]; then
    if miloco_running && miloco_plugin_present; then
      printf 'skip_no_downgrade'
    else
      printf 'reject_no_downgrade'
    fi
    return 0
  fi
  if [[ "$(version_compare "$installed" "$MILOCO_REQUIRED_VERSION")" != "-1" ]] &&
    [[ "$(version_compare "$installed" "$MILOCO_RECOMMENDED_VERSION")" == "-1" ]] &&
    miloco_running && miloco_plugin_present; then
    printf 'optional_update'
    return 0
  fi
  if [[ "$installed" == "$MILOCO_RECOMMENDED_VERSION" ]] && miloco_running && miloco_plugin_present; then
    printf 'skip_up_to_date'
    return 0
  fi
  printf 'install'
}

merge_miloco_plugin_tools() {
  local current current_status merged
  set +e
  current="$(timeout 30s openclaw config get tools.alsoAllow --json 2>/dev/null)"
  current_status=$?
  set -e
  if ((current_status != 0)) || [[ -z "$current" || "$current" == "null" ]]; then
    current='[]'
  fi

  merged="$(python3 -c '
import json, sys
current = json.loads(sys.stdin.read())
if not isinstance(current, list) or not all(isinstance(item, str) for item in current):
    raise SystemExit("tools.alsoAllow is not a string list")
required = {
    "miloco_habit_suggest",
    "miloco_im_push",
    "miloco_notify_bind",
    "miloco_notify_unbind",
}
print(json.dumps(sorted(set(current) | required), ensure_ascii=False))
' <<<"$current")" || die "无法安全合并龙虾插件工具配置"

  timeout 30s openclaw config set tools.alsoAllow "$merged" --strict-json >/dev/null 2>&1 ||
    die "Miloco 插件工具配置失败"
  timeout 30s openclaw config set \
    'plugins.entries["miloco-openclaw-plugin"].hooks.allowConversationAccess' true >/dev/null 2>&1 ||
    die "Miloco 插件会话配置失败"
}

miloco_plugin_version_ready() {
  have openclaw || return 1
  local output
  output="$(timeout 30s openclaw plugins list 2>/dev/null || true)"
  grep -qi 'miloco' <<<"$output" && grep -Fq "$MILOCO_VERSION" <<<"$output"
}

wait_miloco_plugin_version_ready() {
  local attempt
  for attempt in 1 2 3 4 5 6; do
    miloco_plugin_version_ready && return 0
    ((attempt < 6)) && sleep 5
  done
  return 1
}

install_miloco_plugin_fallback() {
  have npm || die "缺少 npm，无法完成 Miloco 插件兼容安装"
  have python3 || die "缺少 Python 3，无法完成 Miloco 插件配置合并"
  have tar || die "缺少 tar，无法解压 Miloco 官方插件包"

  ensure_miloco_plugin_package
  mkdir -p "$MILOCO_PLUGIN_ROOT"
  chmod 700 "$MILOCO_PLUGIN_ROOT" 2>/dev/null || true

  local stage_dir package_dir installed_version declared_main
  stage_dir="$(mktemp -d "$MILOCO_PLUGIN_ROOT/.stage.XXXXXX")"
  package_dir="$stage_dir/package"
  cleanup_miloco_plugin_stage() {
    if [[ -n "${stage_dir:-}" && "$stage_dir" == "$MILOCO_PLUGIN_ROOT"/.stage.* ]]; then
      rm -rf -- "$stage_dir"
    fi
  }
  trap cleanup_miloco_plugin_stage EXIT

  tar -xzf "$MILOCO_PLUGIN_TGZ" -C "$stage_dir" || die "Miloco 官方插件解压失败"
  [[ -f "$package_dir/package.json" && -f "$package_dir/openclaw.plugin.json" ]] ||
    die "Miloco 官方插件内容不完整"
  installed_version="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1], encoding="utf-8")).get("version", ""))' "$package_dir/package.json" 2>/dev/null || true)"
  [[ "$installed_version" == "$MILOCO_VERSION" ]] || die "Miloco 官方插件版本校验失败"
  declared_main="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1], encoding="utf-8")).get("main", ""))' "$package_dir/package.json" 2>/dev/null || true)"
  [[ -n "$declared_main" && -f "$package_dir/${declared_main#./}" ]] ||
    die "Miloco 官方插件缺少可运行入口"

  (
    cd "$package_dir"
    npm install --omit=dev --ignore-scripts --legacy-peer-deps >/dev/null 2>&1
  ) || die "Miloco 插件依赖安装失败"

  if [[ -e "$MILOCO_PLUGIN_DIR" ]]; then
    local existing_version
    existing_version="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1], encoding="utf-8")).get("version", ""))' "$MILOCO_PLUGIN_DIR/package.json" 2>/dev/null || true)"
    [[ "$existing_version" == "$MILOCO_VERSION" && -d "$MILOCO_PLUGIN_DIR/node_modules" ]] ||
      die "面板自有 Miloco 插件目录状态异常，请联系工作人员处理"
  else
    mv "$package_dir" "$MILOCO_PLUGIN_DIR"
  fi

  timeout 60s openclaw plugins install --link "$MILOCO_PLUGIN_DIR" >/dev/null 2>&1 ||
    die "Miloco 插件链接安装失败"
  merge_miloco_plugin_tools
  timeout 90s openclaw gateway restart >/dev/null 2>&1 || die "龙虾后台服务重启失败"
  gateway_ready || die "龙虾后台服务未恢复"
  wait_miloco_plugin_version_ready || die "Miloco 插件安装后未通过版本检查"
  miloco_running || die "Miloco 服务安装后未运行"

  trap - EXIT
  cleanup_miloco_plugin_stage
  printf 'Miloco 插件兼容安装完成，版本 %s。\n' "$MILOCO_VERSION"
}

install_miloco() {
  have openclaw || die "未检测到龙虾环境，请先完成腾讯云龙虾应用模板初始化"

  local decision installed_version
  decision="$(miloco_install_decision)"
  installed_version="$(installed_miloco_version 2>/dev/null || true)"
  case "$decision" in
    skip_no_downgrade)
      printf '检测到已安装 Miloco 版本 %s 高于本面板推荐版本 %s，为避免降级，跳过安装。\n' \
        "$installed_version" "$MILOCO_RECOMMENDED_VERSION"
      return 0
      ;;
    reject_no_downgrade)
      die "检测到已安装 Miloco 版本 ${installed_version} 高于本面板推荐版本 ${MILOCO_RECOMMENDED_VERSION}，为避免降级，本面板不处理该版本的服务或插件修复，请人工核实。"
      ;;
    skip_up_to_date)
      printf 'Miloco 已是推荐版本 %s，服务与插件均正常，跳过安装。\n' "$installed_version"
      return 0
      ;;
    optional_update)
      printf '当前 Miloco 版本 %s 已满足最低兼容要求；推荐版本为 %s。\n' \
        "$installed_version" "$MILOCO_RECOMMENDED_VERSION"
      confirm "是否手动更新到推荐版本？" || {
        printf '已保留当前版本，不执行非必要更新。\n'
        return 0
      }
      ;;
  esac

  ensure_base_main || die "Miloco 2.0 安装脚本下载或版本校验失败"
  ensure_miloco_installer || die "Miloco 2.0 官方安装器下载或校验失败"
  printf '\n开始检查基础环境、修复龙虾后台服务并安装或修复 Miloco 2.0。\n'
  local install_status
  local -a base_runner=(bash "$BASE_MAIN")
  if have setsid; then
    # The official installer reopens /dev/tty when one is available. Detaching
    # this child keeps the base install non-interactive; account binding stays
    # in the dedicated menu action.
    base_runner=(setsid --wait bash "$BASE_MAIN")
  fi
  : >"$MILOCO_OFFICIAL_INSTALL_LOG"
  chmod 600 "$MILOCO_OFFICIAL_INSTALL_LOG" 2>/dev/null || true
  set +e
  MILOCO_VERSION="$MILOCO_VERSION" \
    MILOCO_INSTALLER_URLS="file://$MILOCO_INSTALLER" \
    PYPI_FALLBACK_OFFICIAL=0 \
    DEPLOY_SUPERVISOR=0 \
    INSTALL_ACTION=miloco \
    INSTALL_NONINTERACTIVE=1 \
    RUN_SYSTEM_UPGRADE=0 \
    "${base_runner[@]}" 2>&1 | tee "$MILOCO_OFFICIAL_INSTALL_LOG" | filter_legacy_next_actions
  install_status="${PIPESTATUS[0]}"
  set -e
  if [[ "$install_status" != 0 ]]; then
    if grep -Fq "Cannot read properties of null (reading 'edgesOut')" "$MILOCO_OFFICIAL_INSTALL_LOG"; then
      printf '检测到龙虾插件安装兼容问题，正在使用已校验的官方插件包完成安装。\n'
      install_miloco_plugin_fallback
    else
      die "Miloco 2.0 安装失败"
    fi
  fi
  setup_paths
  have miloco-cli || die "Miloco 2.0 安装后未检测到命令"
  miloco_running || die "Miloco 2.0 安装后服务未运行"
  miloco_plugin_version_ready || die "Miloco 2.0 安装后插件未通过版本检查"
}

configure_mimo_key() {
  have miloco-cli || die "请先安装 Miloco 2.0"

  local api_key=""
  printf '请输入 Miloco 使用的 MiMo API Key（输入内容不会显示）：'
  IFS= read -r -s api_key || api_key=""
  printf '\n'
  [[ -n "$api_key" ]] || die "API Key 不能为空"

  if ! timeout 30s miloco-cli config set model.omni.api_key "$api_key" --no-restart >/dev/null 2>&1; then
    unset api_key
    die "MiMo API Key 写入失败"
  fi
  unset api_key

  if ! timeout 60s miloco-cli service restart >/dev/null 2>&1; then
    timeout 30s miloco-cli service stop >/dev/null 2>&1 || true
    timeout 60s miloco-cli service start >/dev/null 2>&1 || die "Miloco 2.0 重启失败"
  fi
  mimo_key_configured || die "MiMo API Key 写入后未通过检查"
  printf 'Miloco 使用的 MiMo API Key 已配置。\n'
}

configure_mimo_key_if_needed() {
  if mimo_key_configured; then
    printf 'Miloco 使用的 MiMo API Key 已配置，继续下一步。\n'
    return 0
  fi
  configure_mimo_key
}

extract_auth_url() {
  python3 -c '
import re, sys
text = sys.stdin.read()
match = re.search(r"https://account\.xiaomi\.com/oauth2/authorize[^\s<>\"\047]+", text)
if match:
    print(match.group(0).rstrip(")]},.;"))
'
}

authorize_mijia_if_needed() {
  account_bound && return 0

  local bind_output auth_url auth_code=""
  bind_output="$(timeout 30s miloco-cli account bind 2>&1 || true)"
  auth_url="$(extract_auth_url <<<"$bind_output")"
  [[ -n "$auth_url" ]] || die "未能生成米家授权链接"

  printf '\n请在浏览器打开下面的米家授权链接：\n\n%s\n\n' "$auth_url"
  printf '授权完成后，粘贴授权码（输入内容不会显示）：'
  IFS= read -r -s auth_code || auth_code=""
  printf '\n'
  [[ -n "$auth_code" ]] || die "授权码不能为空"

  if ! timeout 60s miloco-cli account authorize "$auth_code" >/dev/null 2>&1; then
    unset auth_code
    die "米家账号绑定失败"
  fi
  unset auth_code
  account_bound || die "米家账号绑定后未通过检查"
  printf '米家账号绑定成功。\n'
}

query_homes() {
  rm -f "$HOME_LIST_JSON" "$HOME_LIST_TSV"
  timeout 30s miloco-cli scope home list >"$HOME_LIST_JSON" 2>/dev/null || return 1
  python3 -m json.tool "$HOME_LIST_JSON" >/dev/null 2>&1 || return 1

  python3 - "$HOME_LIST_JSON" >"$HOME_LIST_TSV" <<'PY'
import json
import sys

data = json.load(open(sys.argv[1], "r", encoding="utf-8"))

def explicit_homes(value):
    if not isinstance(value, list):
        return []
    homes = []
    for item in value:
        if not isinstance(item, dict):
            continue
        home_id = field(item, "home_id", "homeId", "family_id", "familyId")
        name = field(item, "home_name", "homeName", "family_name", "familyName")
        if home_id and name:
            homes.append(item)
    return homes

def find_homes(value):
    homes = explicit_homes(value)
    if homes:
        return homes
    if isinstance(value, dict):
        for key in ("homes", "home_list", "families", "family_list", "data", "result"):
            if key in value:
                homes = find_homes(value[key])
                if homes:
                    return homes
    return []

def field(item, *names):
    for name in names:
        value = item.get(name)
        if value is not None and str(value) != "":
            return str(value)
    return ""

def truthy(value):
    if isinstance(value, bool):
        return value
    return str(value).lower() in ("1", "true", "yes", "y", "current", "selected", "当前", "已启用")

homes = find_homes(data)
for item in homes:
    home_id = field(item, "home_id", "homeId", "family_id", "familyId")
    name = field(item, "home_name", "homeName", "family_name", "familyName")
    active = item.get("in_use", item.get("inUse", item.get("is_in_use", item.get("current", item.get("selected", False)))))
    if home_id and name:
        print(f"{home_id}\t{name}\t{1 if truthy(active) else 0}")
PY

  [[ -s "$HOME_LIST_TSV" ]]
}

save_target_home() {
  local home_id="$1"
  local home_name="$2"
  mkdir -p "$(dirname "$TARGET_HOME_FILE")"
  umask 077
  {
    printf 'XINGUANG_TARGET_HOME=%q\n' "$home_name"
    printf 'XINGUANG_TARGET_HOME_ID=%q\n' "$home_id"
  } >"$TARGET_HOME_FILE"
  chmod 600 "$TARGET_HOME_FILE"
}

select_home() {
  query_homes || die "无法读取米家家庭列表"

  local -a homes=()
  while IFS= read -r home_row; do
    homes+=("$home_row")
  done <"$HOME_LIST_TSV"
  ((${#homes[@]} > 0)) || die "米家家庭列表为空"

  local selected_index=0
  if ((${#homes[@]} == 1)); then
    selected_index=1
    printf '检测到一个家庭：%s\n' "$(cut -f2 <<<"${homes[0]}")"
  else
    printf '\n检测到多个家庭，请选择馨光设备所在家庭：\n\n'
    local i
    for i in "${!homes[@]}"; do
      printf '%d. %s\n' "$((i + 1))" "$(cut -f2 <<<"${homes[$i]}")"
    done
    printf '\n请输入编号：'
    IFS= read -r selected_index || selected_index=0
    [[ "$selected_index" =~ ^[0-9]+$ ]] || die "家庭编号无效"
    ((selected_index >= 1 && selected_index <= ${#homes[@]})) || die "家庭编号无效"
  fi

  local selected home_id home_name
  selected="${homes[$((selected_index - 1))]}"
  IFS=$'\t' read -r home_id home_name _ <<<"$selected"

  timeout 60s miloco-cli scope home switch "$home_id" >/dev/null 2>&1 || die "家庭切换失败"
  local attempt verified=0
  for attempt in $(seq 1 15); do
    sleep 2
    if query_homes && awk -F '\t' -v id="$home_id" '$1 == id && $3 == 1 {found=1} END {exit !found}' "$HOME_LIST_TSV"; then
      verified=1
      break
    fi
  done
  ((verified == 1)) || die "家庭切换后未能确认当前家庭"

  save_target_home "$home_id" "$home_name"
  printf '已选择家庭：%s\n' "$home_name"
}

bind_mijia_and_select_home() {
  have miloco-cli || die "请先安装 Miloco 2.0"
  have python3 || die "缺少 Python 3，无法处理家庭列表"
  authorize_mijia_if_needed
  select_home
}

install_skill() {
  have openclaw || die "请先完成龙虾环境安装"
  have miloco-cli || die "请先安装 Miloco 2.0"
  mimo_key_configured || die "请先配置 Miloco 使用的 MiMo API Key"
  [[ -f "$TARGET_HOME_FILE" ]] || die "请先绑定米家账号并选择家庭"
  ensure_skill_main || die "馨光 Skill 安装脚本下载或版本校验失败"

  printf '\n开始安装或修复馨光 Skill。\n'
  TARGET_HOME_FILE="$TARGET_HOME_FILE" \
    bash "$SKILL_MAIN" install

  local version
  version="$(installed_skill_version 2>/dev/null || true)"
  [[ "$version" == "$SKILL_VERSION" ]] || die "馨光 Skill 安装版本未通过检查"
  gateway_ready || die "龙虾后台服务未就绪"
  skill_registered || die "馨光 Skill 未在龙虾中注册"
  lighting_service_ready || die "灯光服务未通过认证检查"
  printf '馨光 Skill 已安装，版本：%s\n' "$version"
}

full_install() {
  confirm "将依次安装 Miloco 2.0、配置 Miloco 使用的 MiMo API Key、绑定米家并安装馨光 Skill，是否继续？" || return 0
  install_miloco
  configure_mimo_key_if_needed
  bind_mijia_and_select_home
  install_skill
  printf '\n全部安装完成。\n'
}

miloco_cron_match_count() {
  have openclaw || return 1
  local output name found=0
  output="$(timeout 20s openclaw cron list 2>/dev/null || true)"
  [[ -n "$output" ]] || return 1
  for name in perception-digest home-patrol home-dreaming habit-suggest; do
    grep -Fqi "$name" <<<"$output" && found=$((found + 1))
  done
  printf '%d' "$found"
}

report_miloco_cron_state() {
  local found
  if ! found="$(miloco_cron_match_count)"; then
    printf '只读确认：暂时无法读取 Miloco 官方定时任务列表；未修改任何定时任务。\n'
    return 1
  fi
  printf '只读确认：命中 Miloco 官方任务名 %d/4；未修改任何定时任务。\n' "$found"
  ((found == 0))
}

disable_miloco_scheduler() {
  have miloco-cli || die "请先安装 Miloco 2.0"
  local version
  version="$(installed_miloco_version 2>/dev/null || true)"
  [[ -n "$version" ]] || die "无法确认已安装的 Miloco 版本，暂不支持定时任务开关"
  [[ "$(version_compare "$version" "$MILOCO_SCHEDULER_MIN_VERSION")" != "-1" ]] ||
    die "当前 Miloco 版本 $version 不支持官方定时任务开关（需 $MILOCO_SCHEDULER_MIN_VERSION 及以上）"

  printf '\n关闭后将影响 Miloco 官方的感知摘要、家庭巡检、记忆整理、习惯洞察这四项周期任务；不会影响你自己创建的其他定时任务。\n'
  confirm "确认关闭 Miloco 自动定时任务？" || return 0

  timeout 30s miloco-cli config set scheduler.enabled false >/dev/null 2>&1 || die "写入 scheduler.enabled=false 失败"
  [[ "$(miloco_scheduler_state 2>/dev/null || true)" == "关闭" ]] || die "写入后未确认 scheduler.enabled=false"

  have openclaw || die "未检测到龙虾环境，无法重启后台服务使配置生效"
  timeout 90s openclaw gateway restart >/dev/null 2>&1 || die "龙虾后台服务重启失败，配置可能未生效"
  local cron_matches
  if cron_matches="$(miloco_cron_match_count)"; then
    if ((cron_matches == 0)); then
      printf 'Miloco 自动定时任务已关闭，龙虾后台服务已重启使其生效。\n'
    else
      printf 'scheduler.enabled 已关闭，但重启后仍检测到 %d 个 Miloco 官方任务，请联系工作人员复核。\n' "$cron_matches"
    fi
    printf '只读确认：命中 Miloco 官方任务名 %d/4；未修改任何定时任务。\n' "$cron_matches"
  else
    printf 'scheduler.enabled 已关闭，但暂时无法读取 Miloco 官方任务列表，请稍后复核。\n'
  fi
}

enable_miloco_scheduler() {
  have miloco-cli || die "请先安装 Miloco 2.0"
  local version
  version="$(installed_miloco_version 2>/dev/null || true)"
  [[ -n "$version" ]] || die "无法确认已安装的 Miloco 版本，暂不支持定时任务开关"
  [[ "$(version_compare "$version" "$MILOCO_SCHEDULER_MIN_VERSION")" != "-1" ]] ||
    die "当前 Miloco 版本 $version 不支持官方定时任务开关（需 $MILOCO_SCHEDULER_MIN_VERSION 及以上）"

  confirm "确认重新开启 Miloco 自动定时任务？" || return 0

  timeout 30s miloco-cli config set scheduler.enabled true >/dev/null 2>&1 || die "写入 scheduler.enabled=true 失败"
  [[ "$(miloco_scheduler_state 2>/dev/null || true)" == "开启" ]] || die "写入后未确认 scheduler.enabled=true"

  have openclaw || die "未检测到龙虾环境，无法重启后台服务使配置生效"
  timeout 90s openclaw gateway restart >/dev/null 2>&1 || die "龙虾后台服务重启失败，配置可能未生效"
  printf 'Miloco 自动定时任务已重新开启，龙虾后台服务已重启使其生效。\n'
  report_miloco_cron_state || true
}

print_header() {
  clear 2>/dev/null || true
  cat <<EOF
================================================
       馨光 AI 设计灯光 · 安装维护面板
       版本：$PANEL_VERSION
================================================
EOF
}

show_menu() {
  while true; do
    print_header
    cat <<'EOF'

1. 一键安装
2. 安装 / 修复基础环境、龙虾与 Miloco 2.0
3. 配置 Miloco 使用的 MiMo API Key
4. 绑定米家账号 / 选择家庭
5. 安装 / 修复馨光 Skill
6. 查看状态
7. 一键关闭 Miloco 自动定时任务（减少 MiMo 用量）
8. 重新开启 Miloco 自动定时任务
0. 退出
EOF
    printf '\n请选择 [0-8]：'
    local choice
    IFS= read -r choice || choice=0
    case "$choice" in
      1) full_install; pause_menu ;;
      2) confirm "是否检查基础环境并安装或修复龙虾与 Miloco 2.0？" && install_miloco; pause_menu ;;
      3) configure_mimo_key; pause_menu ;;
      4) bind_mijia_and_select_home; pause_menu ;;
      5) confirm "是否安装或修复馨光 Skill？" && install_skill; pause_menu ;;
      6) print_status; pause_menu ;;
      7) disable_miloco_scheduler; pause_menu ;;
      8) enable_miloco_scheduler; pause_menu ;;
      0) return 0 ;;
      *) printf '\n无效选项。\n'; pause_menu ;;
    esac
  done
}

main() {
  setup_paths
  mkdir -p "$CACHE_DIR"
  chmod 700 "$BASE_DIR" "$CACHE_DIR" 2>/dev/null || true
  [[ "$(uname -s)" == Linux ]] || die "本面板仅用于腾讯云 Linux 龙虾服务器"
  have timeout || die "缺少 timeout 命令"
  [[ -t 0 ]] || die "请在腾讯云免密终端中运行本面板"
  install_self

  case "${1:-menu}" in
    menu) show_menu ;;
    status) print_status ;;
    install) full_install ;;
    miloco) install_miloco ;;
    key) configure_mimo_key ;;
    home) bind_mijia_and_select_home ;;
    skill) install_skill ;;
    scheduler-off) disable_miloco_scheduler ;;
    scheduler-on) enable_miloco_scheduler ;;
    version) printf '%s\n' "$PANEL_VERSION" ;;
    *) die "未知操作：${1:-}" ;;
  esac
}

