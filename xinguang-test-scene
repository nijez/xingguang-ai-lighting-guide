#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_TEST_SCENE_VERSION="2026-06-29.1"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
INSTALL_DIR="${INSTALL_DIR:-$HOME/wainfort-light}"
ENV_PRIMARY="/etc/xinguang-wainfort.env"
ENV_FALLBACK="$INSTALL_DIR/.env"
API_PORT="${WAINFORT_API_PORT:-1888}"
API_TOKEN="${WAINFORT_API_TOKEN:-}"
REQUEST_LOG="$BASE_DIR/request-log.jsonl"

load_env() {
  local env_file=""
  if [[ -r "$ENV_PRIMARY" ]]; then
    env_file="$ENV_PRIMARY"
  elif [[ -r "$ENV_FALLBACK" ]]; then
    env_file="$ENV_FALLBACK"
  fi
  if [[ -n "$env_file" ]]; then
    API_TOKEN="$(grep -E '^WAINFORT_API_TOKEN=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
    API_PORT="$(grep -E '^WAINFORT_API_PORT=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
  fi
  API_PORT="${API_PORT:-1888}"
}

json_escape() {
  python3 -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=False))' "$1"
}

main() {
  local room="${1:-}" scene="${2:-}"
  if [[ -z "$room" || -z "$scene" ]]; then
    printf '用法：xinguang-test-scene "客厅" "马尔代夫海边日落"\n'
    exit 2
  fi

  load_env
  mkdir -p "$BASE_DIR"
  if [[ -z "$API_TOKEN" ]]; then
    printf '灯光服务认证信息未配置。\n'
    exit 3
  fi

  local request_id payload tmp code
  request_id="xg-$(date +%Y%m%d%H%M%S)-$RANDOM"
  payload="$(printf '{"request_id":%s,"room":%s,"scene":%s,"text":%s,"single_shot":true}' \
    "$(json_escape "$request_id")" \
    "$(json_escape "$room")" \
    "$(json_escape "$scene")" \
    "$(json_escape "$room $scene")")"
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT

  code="$(curl -sS --max-time 30 -o "$tmp" -w '%{http_code}' \
    -H "Authorization: Bearer $API_TOKEN" \
    -H 'Content-Type: application/json' \
    -d "$payload" \
    "http://127.0.0.1:$API_PORT/api/generate" 2>/dev/null || true)"

  python3 - "$REQUEST_LOG" "$request_id" "$room" "$scene" "$code" "$tmp" <<'PY' >/dev/null 2>&1 || true
import json, sys, datetime, os
path, request_id, room, scene, code, body_path = sys.argv[1:7]
try:
    body = open(body_path, encoding="utf-8", errors="replace").read()[:4000]
except Exception:
    body = ""
entry = {
    "ts": datetime.datetime.now().astimezone().isoformat(),
    "request_id": request_id,
    "room": room,
    "scene": scene,
    "service_called": code not in ("", "000"),
    "http_code": code,
    "response_summary": body[:500],
}
os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path, "a", encoding="utf-8") as f:
    f.write(json.dumps(entry, ensure_ascii=False) + "\n")
PY

  case "$code" in
    200)
      printf '灯光请求已发送，请观察灯光是否变化。\n'
      printf '请求编号：%s\n' "$request_id"
      ;;
    401|403)
      printf '灯光服务认证未通过，请同步授权信息后重试。\n'
      exit 4
      ;;
    000|"")
      printf '灯光服务暂时不可用。\n'
      exit 5
      ;;
    *)
      printf '灯光请求未完成，请联系工作人员处理。\n'
      printf '请求编号：%s\n' "$request_id"
      exit 6
      ;;
  esac
}

main "$@"
