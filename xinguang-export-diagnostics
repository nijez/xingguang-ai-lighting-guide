#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_EXPORT_DIAGNOSTICS_VERSION="2026-06-29.1"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
OUT_DIR="$BASE_DIR/diagnostics"

redact_file() {
  local src="$1" dst="$2"
  if [[ -f "$src" ]]; then
    sed -E \
      -e 's/(Bearer )[A-Za-z0-9._~+\/=-]+/\1***REDACTED***/g' \
      -e 's/(token["'"'"']?[=: ]+)[A-Za-z0-9._~+\/=-]+/\1***REDACTED***/Ig' \
      -e 's/(WAINFORT_[A-Z_]*TOKEN=).*/\1***REDACTED***/g' \
      -e 's/(api_key["'"'"']?[=: ]+)[A-Za-z0-9._~-]+/\1***REDACTED***/Ig' \
      "$src" >"$dst"
  fi
}

main() {
  mkdir -p "$OUT_DIR"
  local work archive stamp
  stamp="$(date +%Y%m%d-%H%M%S)"
  work="$(mktemp -d)"
  archive="$OUT_DIR/xinguang-diagnostics-$stamp.tar.gz"
  trap 'rm -rf "${work:-}"' EXIT

  {
    printf '导出时间：%s\n' "$(date '+%F %T %Z')"
    printf '主机：%s\n' "$(hostname 2>/dev/null || true)"
    printf '用户：%s\n' "$(id -un 2>/dev/null || true)"
  } >"$work/summary.txt"

  if command -v xinguang-doctor >/dev/null 2>&1; then
    xinguang-doctor >"$work/doctor.txt" 2>&1 || true
  elif [[ -x "$BASE_DIR/xinguang-doctor" ]]; then
    "$BASE_DIR/xinguang-doctor" >"$work/doctor.txt" 2>&1 || true
  fi

  [[ -f "$BASE_DIR/VERSION.json" ]] && cp "$BASE_DIR/VERSION.json" "$work/VERSION.json"
  [[ -f "$BASE_DIR/state.json" ]] && cp "$BASE_DIR/state.json" "$work/state.json"
  [[ -f "$BASE_DIR/target-home.env" ]] && redact_file "$BASE_DIR/target-home.env" "$work/target-home.env"
  [[ -f "$BASE_DIR/request-log.jsonl" ]] && redact_file "$BASE_DIR/request-log.jsonl" "$work/request-log.jsonl"
  [[ -f "$BASE_DIR/wainfort-logs/api.log" ]] && redact_file "$BASE_DIR/wainfort-logs/api.log" "$work/api.log"
  [[ -f "$HOME/wainfort-light/.env" ]] && redact_file "$HOME/wainfort-light/.env" "$work/wainfort.env"
  [[ -f "/etc/xinguang-wainfort.env" && -r "/etc/xinguang-wainfort.env" ]] && redact_file "/etc/xinguang-wainfort.env" "$work/systemd.env"

  tar -czf "$archive" -C "$work" .
  printf '诊断包已导出：%s\n' "$archive"
}

main "$@"
